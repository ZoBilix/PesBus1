<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.MyApplication" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Основные цвета: Синий -->
        <item name="colorPrimary">@color/blue</item>
        <item name="colorPrimaryVariant">@color/blue_dark</item>
        <item name="colorOnPrimary">@android:color/black</item>
        
        <item name="colorPrimaryContainer">@color/blue</item>
        <item name="colorOnPrimaryContainer">@android:color/white</item>

        <item name="colorSecondary">@color/blue</item>
        <item name="colorOnSecondary">@android:color/black</item>

        <!-- ТЁМНЫЙ фон -->
        <item name="android:colorBackground">#000000</item>
        <item name="colorSurface">#121212</item>
        <item name="colorOnSurface">@android:color/white</item>

        <!-- Статус бар -->
        <item name="android:statusBarColor">#0288D1</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="CustomBottomSheetDialog" parent="Theme.Material3.Dark.BottomSheetDialog">
        <item name="colorPrimary">@color/blue</item>
        <item name="colorPrimaryContainer">@color/blue</item>
        <item name="colorOnPrimaryContainer">@android:color/white</item>
        <item name="bottomSheetStyle">@style/CustomBottomSheetStyleWrapper</item>
    </style>

    <style name="CustomBottomSheetStyleWrapper" parent="Widget.Material3.BottomSheet.Modal">
        <item name="android:background">@android:color/transparent</item>
    </style>
</resources>