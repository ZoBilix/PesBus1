<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.MyApplication" parent="Theme.Material3.Light.NoActionBar">
        <!-- Основные цвета: Синий -->
        <item name="colorPrimary">@color/blue</item>
        <item name="colorPrimaryVariant">@color/blue_dark</item>
        <item name="colorOnPrimary">@android:color/white</item>
        
        <!-- Цвета для контейнеров (важно для Material3 кнопок) -->
        <item name="colorPrimaryContainer">@color/blue</item>
        <item name="colorOnPrimaryContainer">@android:color/white</item>

        <item name="colorSecondary">@color/blue</item>
        <item name="colorOnSecondary">@android:color/white</item>

        <!-- Фон -->
        <item name="android:colorBackground">@android:color/white</item>
        <item name="colorSurface">@android:color/white</item>
        <item name="colorOnSurface">@android:color/black</item>

        <!-- Статус бар -->
        <item name="android:statusBarColor">@color/blue_dark</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!-- Стиль для BottomSheet -->
    <style name="CustomBottomSheetDialog" parent="Theme.Material3.Light.BottomSheetDialog">
        <item name="colorPrimary">@color/blue</item>
        <item name="colorPrimaryContainer">@color/blue</item>
        <item name="colorOnPrimaryContainer">@android:color/white</item>
        <item name="colorSurface">@android:color/white</item>
        <item name="colorOnSurface">@android:color/black</item>
        <item name="bottomSheetStyle">@style/CustomBottomSheetStyleWrapper</item>
    </style>

    <style name="CustomBottomSheetStyleWrapper" parent="Widget.Material3.BottomSheet.Modal">
        <item name="android:background">@android:color/transparent</item>
    </style>
</resources>